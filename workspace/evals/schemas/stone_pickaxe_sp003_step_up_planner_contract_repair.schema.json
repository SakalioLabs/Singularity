        "sha256": {"const": "3c978d47dbfc0ab6d12fef535577c7399b773ec358dba2fd968bdda01ff1e681"},
        "immutable": {"const": true},
        "rewritten": {"const": false},
        "observation_canonical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "target": {
          "type": "object",
